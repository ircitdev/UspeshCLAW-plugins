# admin-api.js configuration
# Copy to .env and fill values.

# === REQUIRED ===

# Random secret for Bearer auth. Generate with: openssl rand -hex 32
ADMIN_API_TOKEN=CHANGE_ME_openssl_rand_hex_32

# Port to listen on (bound to 127.0.0.1, proxied by Caddy)
ADMIN_API_PORT=18791

# Root directory of your OpenClaw deployment on the VPS
PROJECT_ROOT=/root/openclaw

# === OPTIONAL (defaults derived from PROJECT_ROOT if omitted) ===

# OpenClaw data layout
WORKSPACES_DIR=/root/openclaw/data/openclaw/workspaces
OPENCLAW_CONFIG=/root/openclaw/data/openclaw/openclaw.json
AGENTS_DATA_DIR=/root/openclaw/data/openclaw/agents
TOOLS_DIR=/root/openclaw/tools

# Gateway container
GATEWAY_COMPOSE=/root/openclaw/docker-compose.yml
GATEWAY_CONTAINER=openclaw-gateway
GATEWAY_HEALTH_URL=http://127.0.0.1:18789/healthz
OAUTH_DAEMON_URL=http://localhost:1455

# Web-root for subdomain-related endpoints (Caddy file_server)
WWW_ROOT=/var/www

# Your domain (used to filter subdomains by suffix)
DOMAIN=example.com

# Default agent ID used as fallback in /api/chat and legacy profile lookups
DEFAULT_AGENT=main

# === GCS (only if you use /api/publish-html or /api/cover/overlay upload) ===

# Leave GCS_BUCKET empty to disable uploads — admin-api will return base64 only.
GCS_BUCKET=
GCS_PREFIX=covers
GCS_PREFIX_DEFAULT=openclaw/admin
GCS_KEY_FILE=/root/openclaw/data/openclaw/gcs-key.json
GCS_NODE_PATH=/root/openclaw/data/openclaw/node_modules
GCS_PUBLIC_BASE=https://storage.googleapis.com/YOUR_BUCKET
