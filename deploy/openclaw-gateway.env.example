# OpenClaw Gateway — environment template
# Copy to .env next to docker-compose.yml

# === Project identification ===
PROJECT_NAME=myproject

# === Gateway ===
# Internal token used by admin-api.js and studio to authenticate with the gateway
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=CHANGE_ME_openssl_rand_hex_32

OPENCLAW_LOG_LEVEL=info
OPENCLAW_SANDBOX=0

# === AI providers ===
# At least one of these is required. OpenClaw also supports ChatGPT Plus OAuth
# via the onboard CLI — in that case API keys are optional.
OPENROUTER_API_KEY=
EXA_API_KEY=

# === Telegram bot tokens (one per agent) ===
# Create bots via @BotFather. Leave empty to disable an agent's Telegram channel.
TELEGRAM_MAIN_BOT_TOKEN=
TELEGRAM_ORCHESTRATOR_BOT_TOKEN=
TELEGRAM_CONCIERGE_BOT_TOKEN=
TELEGRAM_HUNTER_BOT_TOKEN=
TELEGRAM_CLOSER_BOT_TOKEN=
TELEGRAM_CRM_BOT_TOKEN=
TELEGRAM_CRITIC_BOT_TOKEN=
TELEGRAM_DEVELOPER_BOT_TOKEN=
TELEGRAM_DESIGNER_BOT_TOKEN=
TELEGRAM_SMM_BOT_TOKEN=
TELEGRAM_ANALYTICS_BOT_TOKEN=

# Optional: chat ID for broadcast notifications (group/channel)
TELEGRAM_GROUP_CHAT_ID=

# === Outbound proxy (optional) ===
# Only needed if LLM APIs are blocked in your country and you need SOCKS5/HTTP proxy.
# Leave empty to disable.
# Format: socks5://user:pass@host:port  OR  http://user:pass@host:port
OUTBOUND_PROXY_URL=

# === Studio (web UI) ===
# Generate: openssl rand -hex 32
STUDIO_ACCESS_TOKEN=CHANGE_ME_openssl_rand_hex_32

# Path on host where OpenClaw Studio source code lives (default: /var/www/openclaw-studio)
# If you don't use Studio, comment out the `studio` service in docker-compose.yml
STUDIO_SOURCE_DIR=/var/www/openclaw-studio
